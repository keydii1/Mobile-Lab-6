<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- Header Banner -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/mainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MOBILE LAB 6"
            android:textColor="@color/secondary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/mainSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Android Document Filter (OpenCV)"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gap="16dp">

            <!-- Control Buttons Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnLoadSample"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Load Sample"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"/>

                <Button
                    android:id="@+id/btnSelectImage"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Select Image"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <!-- Card 1: Original Image -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Original Document (with Shadow)"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivOriginal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/text_secondary"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/tvOriginalPlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="No image loaded"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Run Filter Button & Progress -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnRemoveShadow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Remove Shadow (OpenCV)"
                    android:textColor="@color/background"
                    android:backgroundTint="@color/secondary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/primary"/>
            </FrameLayout>

            <!-- Card 2: Filtered Image -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Processed Document (Shadow Free)"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/surface">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Top Accent Line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:background="@color/success_green"/>

                    <ImageView
                        android:id="@+id/ivFiltered"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:id="@+id/tvFilteredPlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Run filter to see result"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
