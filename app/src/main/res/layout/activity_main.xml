<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Header Banner -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#1E293B"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mainTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPENCV FILTER"
                    android:textColor="@color/secondary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:id="@+id/mainSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Premium Document Shadow Remover"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="#2E3B55"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="OpenCV 4.9.0"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:elevation="2dp"/>
        </RelativeLayout>
        
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/gradient_button_background" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Presets Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_presets"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/presetChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPresetBook"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/preset_book"
                    app:chipIcon="@drawable/ic_book"
                    android:checked="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPresetReceipt"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/preset_receipt"
                    app:chipIcon="@drawable/ic_receipt"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPresetNote"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/preset_note"
                    app:chipIcon="@drawable/ic_note"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPresetCustom"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/preset_custom"
                    app:chipIcon="@drawable/ic_settings"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Dual Image Preview Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Original Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Original"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="@color/surface">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/ivOriginal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter"
                                android:padding="6dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                app:tint="@color/text_secondary"/>

                            <TextView
                                android:id="@+id/tvOriginalPlaceholder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="No Document"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Processed Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Processed"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/surface">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <!-- Indicator line in green -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:background="@color/success_green"/>

                            <ImageView
                                android:id="@+id/ivFiltered"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter"
                                android:padding="6dp"/>

                            <TextView
                                android:id="@+id/tvFilteredPlaceholder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="Tap process"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <!-- Quick Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnLoadSample"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Load Sample"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"/>

                <Button
                    android:id="@+id/btnSelectImage"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Gallery Import"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"/>
            </LinearLayout>

            <!-- Tuning Control Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Header for Control Card -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_adv_settings"
                        android:textColor="@color/secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <ImageButton
                        android:id="@+id/btnReset"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_refresh"
                        app:tint="@color/text_secondary"
                        android:contentDescription="@string/btn_reset"/>
                </RelativeLayout>

                <!-- Filter Type Segmented ChipGroup -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_filter_mode"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/filterModeChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFilterColor"
                        style="@style/Widget.Material3.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_color"
                        android:checked="true"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFilterGray"
                        style="@style/Widget.Material3.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_gray"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFilterOtsu"
                        style="@style/Widget.Material3.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_binary"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFilterAdaptive"
                        style="@style/Widget.Material3.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_adaptive"/>
                </com.google.android.material.chip.ChipGroup>

                <!-- Sliders Section -->
                
                <!-- Dilation Slider -->
                <LinearLayout
                    android:id="@+id/layoutDilation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvDilationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:text="Dilation Kernel Size: 7"/>

                    <SeekBar
                        android:id="@+id/sbDilation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:max="25"
                        android:progress="7"
                        android:splitTrack="false"
                        android:thumb="@drawable/seekbar_thumb"
                        android:progressDrawable="@drawable/seekbar_track"/>
                </LinearLayout>

                <!-- Median Blur Slider -->
                <LinearLayout
                    android:id="@+id/layoutMedianBlur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvMedianBlurLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:text="Median Blur Size: 21"/>

                    <SeekBar
                        android:id="@+id/sbMedianBlur"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:max="51"
                        android:progress="21"
                        android:splitTrack="false"
                        android:thumb="@drawable/seekbar_thumb"
                        android:progressDrawable="@drawable/seekbar_track"/>
                </LinearLayout>

                <!-- Adaptive Threshold Block Size Slider -->
                <LinearLayout
                    android:id="@+id/layoutBlockSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvBlockSizeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:text="Binarization Block Size: 15"/>

                    <SeekBar
                        android:id="@+id/sbBlockSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:max="99"
                        android:progress="15"
                        android:splitTrack="false"
                        android:thumb="@drawable/seekbar_thumb"
                        android:progressDrawable="@drawable/seekbar_track"/>
                </LinearLayout>

                <!-- Adaptive Threshold Constant C Slider -->
                <LinearLayout
                    android:id="@+id/layoutConstantC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvConstantCLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:text="Constant C Offset: 10.0"/>

                    <SeekBar
                        android:id="@+id/sbConstantC"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:max="40"
                        android:progress="30"
                        android:splitTrack="false"
                        android:thumb="@drawable/seekbar_thumb"
                        android:progressDrawable="@drawable/seekbar_track"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Execution Stats Section -->
            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#243049"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_performance_stats"
                    android:textColor="@color/accent_gold"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/tvResolution"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Resolution: - px"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvExecutionTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Execution Time: - ms"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Run & Compare Container -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:id="@+id/btnContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@id/btnCompare"
                    android:layout_marginEnd="8dp">

                    <Button
                        android:id="@+id/btnRemoveShadow"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="@string/btn_apply_filter"
                        android:textColor="#0F172A"
                        android:background="@drawable/gradient_button_background"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/primary"/>
                </FrameLayout>

                <Button
                    android:id="@+id/btnCompare"
                    android:layout_width="60dp"
                    android:layout_height="54dp"
                    android:layout_alignParentEnd="true"
                    android:backgroundTint="@color/surface"
                    app:icon="@drawable/ic_compare"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@color/text_primary"
                    app:cornerRadius="10dp"/>
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
